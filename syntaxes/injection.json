      "patterns": [
        { "name": "meta.embedded.fstring.expression.python", "contentName": "source.python", "begin": "\\{", "end": "\\}", "patterns": [{ "include": "source.python" }] },
        { "include": "source.sql" }
      ]
    },
    {
      "contentName": "meta.embedded.block.html",
      "begin": "(return)\\s+([frubFRUB]*)\\s*(\"\"\"|''')(html)",
      "beginCaptures": {
        "1": { "name": "keyword.control.return.python" },
