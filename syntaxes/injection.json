{
  "scopeName": "py-marked-strings",
  "injectionSelector": "L:source.python -comment -meta.embedded.fstring.expression.python",
  "patterns": [
    {
      "contentName": "text.html.markdown",
      "begin": "(return)\\s+([frubFRUB]*)\\s*(\"\"\"|''')(md)",
      "beginCaptures": {
        "1": { "name": "keyword.control.return.python" },
        "2": { "name": "storage.type.string.python" },
        "3": { "name": "punctuation.definition.string.begin.python" },
        "4": { "name": "comment.line" }
      },
      "end": "^(\\s*\"\"\"|\\s*''')",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.python" }
      },
      "patterns": [
        { "name": "meta.embedded.fstring.expression.python", "contentName": "source.python", "begin": "\\{", "end": "\\}", "patterns": [{ "include": "source.python" }] },
        { "include": "text.html.markdown.indented" }
      ]
    },
    {
      "contentName": "source.sql",
      "begin": "(return)\\s+([frubFRUB]*)\\s*(\"\"\"|''')(sql|--sql)",
      "beginCaptures": {
        "1": { "name": "keyword.control.return.python" },
