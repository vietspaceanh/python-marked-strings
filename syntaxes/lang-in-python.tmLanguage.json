      },
      "patterns": [
        { "include": "#comment-block" },
        { "include": "#md-block-no-fstring" },
        { "include": "text.html.markdown.no-indent#inline" },
        { "match": "['\"]" }
      ]
    },
    "marked-html-string": {
      "contentName": "meta.embedded.block.html",
      "begin": "^[ \\t]*(return)?\\s*(?:\\b([rRuUbBfF]+))?(\"\"\"|''')(html)\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.flow.python" },
