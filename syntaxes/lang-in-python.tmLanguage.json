{
  "scopeName": "injection.marked-strings.python",
  "injectionSelector": "L:source.python -string",
  "patterns": [
    { "include": "#marked-md-string-f" },
    { "include": "#marked-md-string" },
    { "include": "#marked-html-string" },
    { "include": "#marked-sql-string" },
    { "include": "#comment-block" },
    { "include": "#sql-arg-pattern" },
    { "include": "#el-arg-pattern" }
  ],
  "repository": {
    "marked-md-string-f": {
      "contentName": "meta.embedded.block.markdown",
      "begin": "^[ \\t]*(return)\\s+\\b([rRuUbBfF]*[fF][rRuUbBfF]*)(\"\"\"|''')(md)\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.flow.python" },
        "2": { "name": "storage.type.string.python" },
        "3": { "name": "punctuation.definition.string.begin.python" },
        "4": { "name": "comment.line.marked-string.python" }
      },
      "end": "\\s+(\"\"\"|''')(?!\\S)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.python" }
      },
      "patterns": [
        { "include": "#comment-block" },
        { "include": "#md-block" },
        { "include": "text.html.markdown.no-indent#inline" },
        { "match": "['\"]" }
      ]
    },
    "marked-md-string": {
      "contentName": "meta.embedded.block.markdown",
      "begin": "^[ \\t]*(return)\\s+(?:\\b([rRuUbB]*))?(\"\"\"|''')(md)\\s*$",
