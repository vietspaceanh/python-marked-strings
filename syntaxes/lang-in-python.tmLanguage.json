        { "include": "text.html.markdown.no-indent#separator" },
        { "include": "text.html.markdown.no-indent#fenced_code_block" },
        {
          "begin": "(?:^|\\G)[ ]*([*+-])\\s+",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.list.begin.markdown" }
          },
          "end": "$",
          "name": "markup.list.unnumbered.markdown",
          "patterns": [
            { "include": "text.html.markdown.no-indent#inline" },
            { "match": "['\"]" }
          ]
        },
        {
