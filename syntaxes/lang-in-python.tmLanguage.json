    "sql-arg-pattern": {
      "patterns": [
        {
          "contentName": "meta.embedded.block.sql",
          "begin": "\\b(sql|plot)(\\s*\\()\\s*([rRuUbBfF]*)(\"\"\"|''')",
          "beginCaptures": {
