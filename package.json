{
  "name": "py-marked-strings",
  "displayName": "Python Marked Strings",
  "publisher": "vietspaceanh",
  "repository": {
    "type": "git",
    "url": "https://github.com/vietspaceanh/python-marked-strings"
  },
  "bugs": {
    "url": "https://github.com/vietspaceanh/python-marked-strings/issues"
  },
  "version": "0.2.0",
  "description": "Highlight SQL, Markdown and HTML inside Python marked strings using markers like \"\"\"md, \"\"\"sql, \"\"\"html",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:python"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "grammars": [
      {
        "path": "./syntaxes/markdown-no-indent.tmLanguage.json",
        "scopeName": "text.html.markdown.no-indent"
      },
      {
        "path": "./syntaxes/lang-in-python.tmLanguage.json",
        "scopeName": "injection.marked-strings.python",
        "injectTo": [
          "source.python"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.markdown": "markdown",
          "meta.embedded.block.html": "html",
          "meta.embedded.block.sql": "sql",
          "meta.embedded.block.python": "python"
        }
      }
    ]
  },
  "devDependencies": {
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
